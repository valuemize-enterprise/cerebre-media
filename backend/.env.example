# ════════════════════════════════════════════════════════════════
# Cerebre Intelligence Platform — All Environment Variables
# Copy this to .env and fill in values. NEVER commit .env to Git.
# ════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── PostgreSQL (Supabase) ────────────────────────────
# Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ── Redis (Upstash) ──────────────────────────────────
REDIS_URL=rediss://default:[PASSWORD]@xxxxx.upstash.io:6379

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_40_characters_change_this
JWT_EXPIRES_IN=7d

# ── Anthropic Claude AI ──────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Cloudflare R2 ────────────────────────────────────
# Cloudflare → R2 → Manage R2 API tokens
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
S3_BUCKET_NAME=cerebre-media-files
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_REGION=auto

# ── App ───────────────────────────────────────────────
# Set to your Vercel URL after deploying frontend
FRONTEND_URL=https://your-app.vercel.app
MAX_FILE_SIZE_MB=50

# ── CRM (optional) ───────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ── Email (optional - for digest/alert emails) ────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@cerebre.media

# ── Slack Alerts (optional) ──────────────────────────
SLACK_WEBHOOK_URL=
